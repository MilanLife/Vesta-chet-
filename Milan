const SecurityGuard = ({ content }) => {
  // यह फंक्शन AI का बेसिक स्ट्रक्चर है जो आपत्तिजनक शब्दों या इमेज को चेक करेगा
  const checkSafety = (text) => {
    const offensiveWords = ["abuse", "badword1", "badword2"]; // यहाँ आप लिस्ट बढ़ा सकते हैं
    return offensiveWords.some(word => text.toLowerCase().includes(word));
  };

  const isSafe = !checkSafety(content);

  return (
    <div className="p-4">
      {isSafe ? (
        <div className="text-green-500 font-bold">✅ AI Verified: Content is Safe</div>
      ) : (
        <div className="text-red-500 font-bold">⚠️ AI Alert: Content Flagged!</div>
      )}
    </div>
  );
};

